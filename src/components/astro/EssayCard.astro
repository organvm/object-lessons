---
interface Props {
  title: string;
  slug: string;
  object: string;
  type: string;
  date: Date;
  excerpt: string;
  relatedEpisode?: string;
}

const { title, slug, object, type, date, excerpt, relatedEpisode } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border-b border-divider py-6 last:border-b-0">
  <div class="flex items-baseline gap-3 flex-wrap mb-1">
    <a
      href={`/essays/${slug}`}
      class="font-serif text-lg font-medium text-primary no-underline hover:text-link leading-snug"
    >
      {title}
    </a>
    <span class="text-xs font-sans font-medium px-2 py-0.5 rounded bg-data-bg text-secondary uppercase tracking-wider flex-shrink-0">
      {type}
    </span>
  </div>

  <div class="flex items-center gap-3 text-xs text-secondary mb-2 flex-wrap">
    <span class="text-accent font-medium">{object}</span>
    <span>·</span>
    <time datetime={date.toISOString()}>{formattedDate}</time>
    {relatedEpisode && type === 'companion' && (
      <>
        <span>·</span>
        <a href={`/episodes/${relatedEpisode}`} class="text-link hover:underline">
          View episode →
        </a>
      </>
    )}
  </div>

  <p class="text-sm text-secondary leading-relaxed m-0 line-clamp-3">
    {excerpt}
  </p>
</article>

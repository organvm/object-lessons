---
interface Props {
  status: 'published' | 'in-production' | 'scripted' | 'planned' | 'researching' | 'candidate';
}

const { status } = Astro.props;

const colorMap: Record<string, string> = {
  'published': 'bg-green-100 text-green-800',
  'in-production': 'bg-amber-100 text-amber-800',
  'scripted': 'bg-sky-100 text-sky-800',
  'planned': 'bg-gray-100 text-gray-600',
  'researching': 'bg-blue-100 text-blue-800',
  'candidate': 'bg-gray-100 text-gray-800',
};

const classes = colorMap[status] ?? 'bg-gray-100 text-gray-800';
---

<span
  class:list={[
    'inline-block px-2 py-0.5 rounded-full text-xs font-sans font-medium uppercase tracking-wider',
    classes,
  ]}
>
  {status}
</span>

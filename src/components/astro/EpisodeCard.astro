---
import StatusBadge from './StatusBadge.astro';

interface Props {
  title: string;
  slug: string;
  object: string;
  version: 'v1' | 'v2';
  status: 'published' | 'in-production' | 'scripted' | 'planned' | 'researching' | 'candidate';
  duration: string;
  date: Date;
  youtubeId: string;
}

const { title, slug, object, version, status, duration, date, youtubeId } = Astro.props;

const thumbUrl = `https://img.youtube.com/vi/${youtubeId}/mqdefault.jpg`;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-divider rounded overflow-hidden bg-surface hover:border-accent transition-colors duration-150">
  <a href={`/episodes/${slug}`} class="block no-underline" aria-label={title}>
    <div class="aspect-video overflow-hidden bg-data-bg">
      <img
        src={thumbUrl}
        alt={`Thumbnail for ${title}`}
        class="w-full h-full object-cover transition-transform duration-200 group-hover:scale-[1.02]"
        loading="lazy"
      />
    </div>
  </a>

  <div class="p-4 flex flex-col gap-2">
    <div class="flex items-start justify-between gap-2">
      <a
        href={`/episodes/${slug}`}
        class="font-serif text-base font-medium text-primary no-underline hover:text-link leading-snug"
      >
        {title}
      </a>
      <span class="flex-shrink-0 text-xs font-mono font-semibold px-1.5 py-0.5 rounded border border-divider text-secondary uppercase tracking-wider">
        {version}
      </span>
    </div>

    <p class="text-sm text-accent m-0">{object}</p>

    <div class="flex items-center gap-3 flex-wrap">
      <StatusBadge status={status} />
      <span class="text-xs text-secondary">{duration}</span>
      <time datetime={date.toISOString()} class="text-xs text-secondary ml-auto">
        {formattedDate}
      </time>
    </div>
  </div>
</article>
